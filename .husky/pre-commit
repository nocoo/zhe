# Run independent stages in parallel; fail fast on any non-zero exit.
# Each stage's stdout/stderr is buffered to a tempfile and replayed in order
# so logs stay readable.
set -o pipefail
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$HOOK_DIR/../scripts/ensure-tools.sh"
require_tool gitleaks "secrets scanning"

TMPDIR_HOOK=$(mktemp -d -t zhe-precommit-XXXXXX)
trap 'rm -rf "$TMPDIR_HOOK"' EXIT

run_bg() {
  local name="$1"; shift
  ( "$@" >"$TMPDIR_HOOK/$name.log" 2>&1; echo $? >"$TMPDIR_HOOK/$name.exit" ) &
  eval "PID_$name=$!"
}

wait_stage() {
  local name="$1" pid_var="PID_$1" pid status
  pid=${!pid_var}
  wait "$pid" 2>/dev/null || true
  status=$(cat "$TMPDIR_HOOK/$name.exit" 2>/dev/null || echo 1)
  echo "━━━ $name (exit=$status) ━━━"
  cat "$TMPDIR_HOOK/$name.log"
  if [ "$status" -ne 0 ]; then
    echo "❌ pre-commit stage '$name' failed" >&2
    exit "$status"
  fi
}

# Launch all four stages concurrently.
run_bg unit_cov   bun run test:unit:coverage
run_bg integ      bun run test:integration
run_bg typecheck  bun run typecheck
run_bg lint       bunx lint-staged
run_bg gitleaks   gitleaks protect --staged --no-banner

# Wait in declaration order so logs print deterministically.
wait_stage unit_cov
wait_stage integ
wait_stage typecheck
wait_stage lint
wait_stage gitleaks
