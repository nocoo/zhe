# ─── Required ────────────────────────────────────────────────────────────────
# AUTH_SECRET: generate with `openssl rand -base64 32`
AUTH_SECRET=
# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET: from Google Cloud Console
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# CLOUDFLARE_ACCOUNT_ID: from Cloudflare Dashboard → Account ID
CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_D1_DATABASE_ID: zhe-db UUID from `npx wrangler d1 list`
CLOUDFLARE_D1_DATABASE_ID=
# CLOUDFLARE_API_TOKEN: from Cloudflare Dashboard → API Tokens
CLOUDFLARE_API_TOKEN=

# ─── Optional: File Upload (R2) ──────────────────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_BUCKET_NAME=zhe
# R2_PUBLIC_DOMAIN: e.g. https://s.zhe.to
R2_PUBLIC_DOMAIN=
R2_USER_HASH_SALT=

# ─── Optional: Security ─────────────────────────────────────────────────────
# WORKER_SECRET: shared secret for sync-kv and record-click endpoints
WORKER_SECRET=

# ─── D1 Proxy (Worker D1 binding path — faster than HTTP API) ───────────────
# D1_PROXY_URL: Production Worker URL for dev server
D1_PROXY_URL=
# D1_PROXY_SECRET: Shared secret for D1 proxy authentication
D1_PROXY_SECRET=

# ─── Test Resources (required for L2/L3 E2E tests) ──────────────────────────
# These are REQUIRED for running tests. The pre-push hook will fail without them.
#
# D1_TEST_DATABASE_ID: zhe-db-test UUID (must NOT equal CLOUDFLARE_D1_DATABASE_ID)
D1_TEST_DATABASE_ID=
# D1_TEST_PROXY_URL: Test Worker URL (must contain "-test" in the URL)
D1_TEST_PROXY_URL=
# D1_TEST_PROXY_SECRET: Test Worker D1 proxy secret
D1_TEST_PROXY_SECRET=
# R2_TEST_BUCKET_NAME: Test R2 bucket name
R2_TEST_BUCKET_NAME=zhe-test
# R2_TEST_PUBLIC_DOMAIN: Test R2 public domain (placeholder, no real DNS needed)
R2_TEST_PUBLIC_DOMAIN=https://test-r2.zhe.to
# KV_TEST_NAMESPACE_ID: zhe-test KV namespace ID
KV_TEST_NAMESPACE_ID=
