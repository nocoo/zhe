  "browserslist": [
    "chrome >= 96",
    "firefox >= 95",
    "safari >= 15.4",
    "edge >= 96"
  ],
  "overrides": {
    "esbuild": ">=0.25.0",
    "fast-xml-parser": ">=5.5.7",
    "flatted": ">=3.4.2",
