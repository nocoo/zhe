    "test:api": "bun run scripts/run-api-e2e.ts",
    "test:e2e:pw": "bun x playwright test",
    "test:e2e:pw:ui": "bun x playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "sync-kv": "bun run scripts/sync-kv.ts",
