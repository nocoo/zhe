{
  "name": "zhe",
  "version": "1.9.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 7005",
    "build": "next build",
    "start": "next start -p 7005",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "bash scripts/typecheck.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --exclude 'tests/api/**' --exclude 'tests/integration/**'",
    "test:unit:coverage": "vitest run --exclude 'tests/api/**' --exclude 'tests/integration/**' --coverage",
    "test:integration": "vitest run tests/integration",
    "test:api": "bun run scripts/run-api-e2e.ts",
    "test:e2e:pw": "bun x playwright test",
    "test:e2e:pw:ui": "bun x playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "sync-kv": "bun run scripts/sync-kv.ts",
    "generate:logos": "./scripts/generate-logos.sh",
    "release": "bun run scripts/release.ts",
    "prepare": "husky"
  },
  "dependencies": {
